{
  "expo": {
    "name": "MedMap",
    "slug": "medmap-kz",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "medmap",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "kz.medmap.app"
    },
    "android": {
      "package": "kz.medmap.app",
      "adaptiveIcon": {
        "backgroundColor": "#1A5276",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
  "expo-router",
  "expo-location",
  [
    "@rnmapbox/maps",
    {
      "RNMapboxMapsDownloadToken": "pk.eyJ1IjoibWVkbWFwa3oiLCJhIjoiY21td2w2ZmdoMnZocjJwcXRscmxqdmhvciJ9.jA273Yx0_SBhQf1NK6baJQ"
    }
  ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1A5276",
          "dark": {
            "backgroundColor": "#1A5276"
          }
        }
      ],
      "@rnmapbox/maps"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
